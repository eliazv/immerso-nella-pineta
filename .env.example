# .env.example — Riferimento per tutte le variabili d'ambiente del progetto
# Copia le variabili necessarie in .env.local e compila con i tuoi valori reali.
# NON mettere valori reali in questo file (è committato su git).
#
# NOTA: questo progetto usa Vite — tutte le variabili DEVONO avere prefisso VITE_

# ── Obbligatorie ────────────────────────────────────────────────────────────────

# ID del Google Sheet (foglio principale con i dati delle prenotazioni)
VITE_GOOGLE_SHEET_ID=156gOCNUFzwT4hmpxn2_9GE9Ionzlng3Rw0rAzoaktuc

# URL della Web App Google Apps Script (per CRUD prenotazioni)
# Ottienilo da: Google Sheet → Estensioni → Apps Script → Distribuisci → Nuova distribuzione
VITE_GOOGLE_SCRIPT_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ── Opzionali ───────────────────────────────────────────────────────────────────

# GitHub Personal Access Token — per caricare allegati via Gist (emailAttachmentService.ts)
VITE_GITHUB_TOKEN=your_github_token_here
